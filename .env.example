# Backend environment variables for shorter-link-backend
# Example MongoDB connection string: mongodb://localhost:27017/shorter-link
# or mongodb+srv://<user>:<password>@cluster.example.net/<dbname>?retryWrites=true&w=majority
MONGO_DB_CONNECTIONSTRING=xxx

PORT=3001
CORS_ORIGIN=http://localhost:3000

# Short URL generation settings
# NOTE: this value is treated as minutes, not days
SHORT_URL_LENGTH=6
SHORT_URL_EXPIRATION_DAYS=3

JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_TTL=1800

DAILY_SHORTEN_LIMIT=10
MAX_GROUPS_COUNT=5
MAX_MEMBERS_PER_GROUP=10
MAX_LINKS_PER_GROUP=20

# Default admin seed account
ADMIN_USERNAME=admin
ADMIN_FULLNAME=xxx
ADMIN_PASSWORD=xxx

# Redis Cloud
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here
REDIS_HOST=your_redis_host_here
REDIS_PORT=13166

# WebSocket server URL for notifications
WS_URL=http://localhost:3002